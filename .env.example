# gsdb (Google Sheets proxy)
GSDB_URL="https://gsdb.yourdomain.com"
GSDB_APP_ID="uohmi"
GSDB_API_KEY="your-gsdb-api-key"

# Auth
ADMIN_PASSWORD="your-admin-password"
SESSION_SECRET="generate-with: openssl rand -hex 32"

# Email (Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="uohmi <invoices@yourdomain.com>"

# Notifications (ntfy.sh) - optional
NTFY_TOPIC="uohmi-your-secret-word"
NTFY_INCLUDE_PII="false"

# AI (optional - for receipt parsing on the new invoice page)
# Option A: Vercel AI Gateway (GPT-5 nano) - recommended in production
AI_GATEWAY_API_KEY="your-vercel-ai-gateway-key"

# Option B: Any OpenAI-compatible API (Ollama, vLLM, LM Studio, etc.) - useful locally
# OPENAI_BASE_URL="http://localhost:11434/v1"
# OPENAI_API_KEY="ollama"  # often not required for local
# OPENAI_MODEL="gemma4:e2b"

# App - optional; auto-detected from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL on Vercel
# NEXT_PUBLIC_APP_URL="http://localhost:3000"